{
    "name": "Fleet Card",
    "module": "Fuel Management",
    "custom": 0,
    "fields": [
        {
            "fieldname": "card_name",
            "label": "Card Name / Number",
            "fieldtype": "Data",
            "reqd": 1,
            "unique": 1
        },
        {
            "fieldname": "customer",
            "label": "Customer",
            "fieldtype": "Link",
            "options": "Customer",
            "reqd": 1
        },
        {
            "fieldname": "linked_fuel_product",
            "label": "Linked Fuel Product",
            "fieldtype": "Link",
            "options": "Item"
        },
        {
            "fieldname": "discounted_price",
            "label": "Discounted Price",
            "fieldtype": "Currency"
        },
        {
            "fieldname": "opening_balance",
            "label": "Opening Balance",
            "fieldtype": "Currency",
            "default": "0"
        },
        {
            "fieldname": "status",
            "label": "Status",
            "fieldtype": "Select",
            "options": "Active\nSuspended\nClosed",
            "default": "Active"
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1
        }
    ],
    "naming_rule": "By fieldname",
    "autoname": "field:card_name"
}